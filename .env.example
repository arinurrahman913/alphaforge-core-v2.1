# Salin file ini jadi `.env` (di root repo), lalu isi key kamu.
# File `.env` sudah di-gitignore — TIDAK akan ter-commit.
# Setelah `.env` ada, backend/CLI/scheduled-task otomatis membacanya
# (via python-dotenv) — tidak perlu set $env:FRED_API_KEY manual lagi.

# FRED API key gratis: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

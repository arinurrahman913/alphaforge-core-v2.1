# Salin file ini jadi `.env` (di root repo), lalu isi key kamu.
# File `.env` sudah di-gitignore — TIDAK akan ter-commit.
# Setelah `.env` ada, backend/CLI/scheduled-task otomatis membacanya
# (via python-dotenv) — tidak perlu set $env:FRED_API_KEY manual lagi.

# FRED API key gratis: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub API key gratis (60 req/menit): https://finnhub.io/register
# Tanpa ini, Evidence.news selalu status="missing" untuk semua ticker
# (lihat alphaforge/layer2/sources/finnhub.py) — bukan error, cuma degradasi
# graceful, tapi berarti tab News di dashboard kosong.
FINNHUB_API_KEY=your_finnhub_api_key_here
